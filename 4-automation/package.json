{
  "name": "sigap-qa-automation",
  "version": "1.0.0",
  "description": "Automation test suite untuk SIGAP Web Application menggunakan Playwright",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:a11y": "playwright test tests/aksesibilitas.spec.ts",
    "test:seo": "playwright test tests/seo.spec.ts",
    "test:nav": "playwright test tests/navigasi.spec.ts",
    "test:resp": "playwright test tests/responsivitas.spec.ts",
    "test:login": "playwright test tests/login.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@axe-core/playwright": "^4.9.1",
    "axe-core": "^4.9.1"
  }
}
